void setup() {
  myStepper.setSpeed(10);
  Serial.begin(9600);
  delay(2000);
}

void loop() {
  Serial.println("Forward");
  myStepper.step(2048);   // One revolution forward
  delay(2000);
  
  Serial.println("Reverse");
  myStepper.step(-2048);  // One revolution reverse
  delay(2000);
}
